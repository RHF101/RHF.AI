# ============================================================
# GODOT AI FORGE — Environment Variables
# ============================================================
# CARA PAKAI:
# 1. Copy file ini, rename jadi .env
# 2. Isi semua value di bawah dengan API key lo
# 3. JANGAN commit file .env ke GitHub! (sudah ada di .gitignore)
# 4. Di Vercel: Settings → Environment Variables → tambah satu-satu
# ============================================================

# ── GEMINI AI (Google) ──
# Dapatkan di: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── TAVILY SEARCH ──
# Dapatkan di: https://app.tavily.com
VITE_TAVILY_API_KEY=tvly-your_tavily_api_key_here

# ── FIREBASE ──
# Dapatkan di: https://console.firebase.google.com
# Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ── CANVA API ──
# Dapatkan di: https://www.canva.com/developers
# Apps → Create app → Get credentials
VITE_CANVA_PUBLIC_KEY=your_canva_public_key_here
VITE_CANVA_KID=your_canva_kid_here

# ── APP CONFIG ──
VITE_APP_NAME=GODOT AI FORGE
VITE_APP_VERSION=1.0.0
